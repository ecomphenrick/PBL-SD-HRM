module top_level (
    // --- Globais ---
    input  wire        clk,
    input  wire        reset,

    // --- FSM (pbl) ---
    input  wire        start,
    input  wire        ok,
    input  wire        err,
    output wire        done,
    output wire        error,

    // --- Bias (ROM 128x16) ---
    input  wire [6:0]  bias_addr,
    output wire [15:0] bias_q,

    // --- Pesos (ROM 100352x16) ---
    input  wire [16:0] pesos_addr,
    output wire [15:0] pesos_q,

    // --- Beta (RAM 1280x16) ---
    input  wire [10:0] beta_addr,
    input  wire [15:0] beta_data,
    input  wire        beta_wren,
    output wire [15:0] beta_q
);

    pbl u_pbl (
        .clk   (clk),
        .reset (reset),
        .start (start),
        .ok    (ok),
        .err   (err),
        .done  (done),
        .error (error)
    );

    Bias u_bias (
        .address (bias_addr),
        .clock   (clk),
        .q       (bias_q)
    );

    Pesos u_pesos (
        .address (pesos_addr),
        .clock   (clk),
        .q       (pesos_q)
    );

    Beta u_beta (
        .address (beta_addr),
        .clock   (clk),
        .data    (beta_data),
        .wren    (beta_wren),
        .q       (beta_q)
    );

endmodule