module memorias_elm (

    input wire clk,

    // endereço pesos
    input wire [16:0] addr_w,
    output reg [15:0] peso,

    // endereço vieses
    input wire [6:0] addr_b,
    output reg [15:0] bias

);

// =============================
// MEMORIA DE PESOS
// =============================
// 128 neurônios × 784 pixels = 100352 pesos

(* ram_init_file = "win.mif" *)
reg [15:0] mem_pesos [0:100351];

always @(posedge clk)
begin
    peso <= mem_pesos[addr_w];
end


// =============================
// MEMORIA DE BIAS
// =============================
// 128 valores

(* ram_init_file = "b.mif" *)
reg [15:0] mem_bias [0:127];

always @(posedge clk)
begin
    bias <= mem_bias[addr_b];
end


endmodule